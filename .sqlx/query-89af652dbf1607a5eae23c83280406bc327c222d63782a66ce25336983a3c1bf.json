  "query": "\n            SELECT\n                id,\n                market_id,\n                q_yes,\n                q_no,\n                liquidity_b,\n                price_yes,\n                price_no,\n                created_at\n            FROM polymarket.market_state_history\n            WHERE market_id = $1\n              AND created_at BETWEEN $2 AND $3\n            ORDER BY created_at ASC\n            ",
