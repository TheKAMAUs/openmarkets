  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id,\n            name,\n            description,\n            logo,\n            status as \"status: MarketStatus\",\n            final_outcome as \"final_outcome: Outcome\",\n            liquidity_b,\n            market_expiry,\n            created_at,\n            updated_at,\n            parent_id,\n            is_event,\n            child_market_ids,\n            category,\n            resolution_criteria,\n            slug,\n            q_yes,\n            q_no\n        FROM \"polymarket\".\"markets\"\n        WHERE status = $1\n        ORDER BY created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
