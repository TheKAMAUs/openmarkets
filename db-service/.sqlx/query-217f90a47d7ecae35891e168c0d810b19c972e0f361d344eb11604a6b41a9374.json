  "query": "\n        UPDATE polymarket.market_suggestions \n        SET \n            status = $1,\n            admin_notes = COALESCE($2, admin_notes),\n            updated_at = NOW()\n        WHERE id = $3\n        RETURNING \n            id, user_id, title, description, category, upvotes,\n            status as \"status: SuggestionStatus\",  -- ✅ Cast to enum\n            admin_notes, created_at, updated_at\n        ",
